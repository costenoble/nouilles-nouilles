# Notifications de réservation / contact (optionnel)
# Sans ces variables, le site fonctionne en mode démo (aucun e-mail envoyé).
# Crée une clé sur https://resend.com puis renseigne :

RESEND_API_KEY=
# Adresse qui reçoit les réservations et messages
RESTAURANT_EMAIL=bonjour@nouilles-nouilles.fr
# Expéditeur (par défaut, le bac à sable Resend). Pour un envoi pro, vérifie ton domaine sur Resend.
RESEND_FROM=Nouilles Nouilles <onboarding@resend.dev>
